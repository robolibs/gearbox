    def Xform "wheel_rear_right" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 260.0
        vector3f physics:diagonalInertia = (68, 38, 38)
        double3 xformOp:translate = (-1.4, 2.688, 0.768)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        def Xform "tyre" (prepend references = @./tractor.usdc@</root/wheel_front_right_tyre>)
        {
