            float3 xformOp:scale = (0.463, 0.406, 0.406)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
        def Cylinder "tire_collider" (prepend apiSchemas = ["PhysicsCollisionAPI"])
        {
            token visibility = "invisible"
            uniform token axis = "X"
            double radius = 0.768
            double height = 0.7
        }
    }

    def Scope "Joints"
    {
        def PhysicsRevoluteJoint "steer_front_left"
        {
            rel physics:body0 = </robot/chassis>
            rel physics:body1 = </robot/steer_front_left>
            point3f physics:localPos0 = (1.4, -2.304, -0.1445)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "Z"
            float physics:lowerLimit = -16
            float physics:upperLimit = 16
        }
        def PhysicsRevoluteJoint "rev_front_left"
        {
            rel physics:body0 = </robot/steer_front_left>
            rel physics:body1 = </robot/wheel_front_left>
            point3f physics:localPos0 = (0, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "X"
        }

        def PhysicsRevoluteJoint "steer_front_right"
        {
            rel physics:body0 = </robot/chassis>
            rel physics:body1 = </robot/steer_front_right>
            point3f physics:localPos0 = (-1.4, -2.304, -0.1445)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "Z"
            float physics:lowerLimit = -16
            float physics:upperLimit = 16
        }
        def PhysicsRevoluteJoint "rev_front_right"
        {
            rel physics:body0 = </robot/steer_front_right>
            rel physics:body1 = </robot/wheel_front_right>
            point3f physics:localPos0 = (0, 0, 0)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "X"
        }

        def PhysicsRevoluteJoint "rev_middle_left"
        {
            rel physics:body0 = </robot/chassis>
            rel physics:body1 = </robot/wheel_middle_left>
            point3f physics:localPos0 = (1.4, -0.100, -0.1445)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "X"
        }
        def PhysicsRevoluteJoint "rev_middle_right"
        {
            rel physics:body0 = </robot/chassis>
            rel physics:body1 = </robot/wheel_middle_right>
            point3f physics:localPos0 = (-1.4, -0.100, -0.1445)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "X"
        }

        def PhysicsRevoluteJoint "steer_rear_left"
        {
            rel physics:body0 = </robot/chassis>
            rel physics:body1 = </robot/steer_rear_left>
            point3f physics:localPos0 = (1.4, 2.688, -0.1445)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            uniform token physics:axis = "Z"
            float physics:lowerLimit = -29
            float physics:upperLimit = 29
        }
        def PhysicsRevoluteJoint "rev_rear_left"
        {
            rel physics:body0 = </robot/steer_rear_left>
            rel physics:body1 = </robot/wheel_rear_left>
