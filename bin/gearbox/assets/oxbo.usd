        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 260.0
        vector3f physics:diagonalInertia = (68, 38, 38)
        double3 xformOp:translate = (-1.4, -0.100, 0.768)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        def Xform "tyre" (prepend references = @./tractor.usdc@</root/wheel_front_right_tyre>)
        {
            double3 xformOp:translate = (1.439, 1.998, -0.853)
            float3 xformOp:scale = (0.463, 0.406, 0.406)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
        def Xform "tractor_rim" (prepend references = @./tractor.usdc@</root/wheel_front_right_rim>)
        {
            double3 xformOp:translate = (1.439, 1.998, -0.853)
            float3 xformOp:scale = (0.463, 0.406, 0.406)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
        def Cylinder "tire_collider" (prepend apiSchemas = ["PhysicsCollisionAPI"])
        {
            token visibility = "invisible"
            uniform token axis = "X"
            double radius = 0.768
            double height = 0.7
        }
    }

    def Xform "wheel_rear_left" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 260.0
        vector3f physics:diagonalInertia = (68, 38, 38)
        double3 xformOp:translate = (1.4, 2.688, 0.768)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        def Xform "tyre" (prepend references = @./tractor.usdc@</root/wheel_front_left_tyre>)
        {
            double3 xformOp:translate = (-1.463, 1.998, -0.853)
            float3 xformOp:scale = (0.463, 0.406, 0.406)
