export TOP_HEAD="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"

# Snapshot the running NVIDIA driver version into an env var. The flake reads
# it via `builtins.getEnv` under `--impure`; passing it as a file would fail,
# because flakes in a git repo only expose tracked files to the evaluator and
# anything under `.direnv/` is gitignored globally.
if [ -r /proc/driver/nvidia/version ]; then
  # Line 1 shape: "NVRM version: ... Module for x86_64  580.126.09  Release Build ..."
  export GEARBOX_NVIDIA_VERSION="$(head -n1 /proc/driver/nvidia/version \
    | sed -nE 's/.*  ([0-9.]+)  Release.*/\1/p')"
fi

use flake --impure --option warn-dirty false

export PATH="$PATH:$PWD/target/debug:$PWD/target/release"

export_alias _b "cd $TOP_HEAD && make build; cd -"
export_alias _c "cd $TOP_HEAD && make compile; cd -"
export_alias _r "cd $TOP_HEAD && make run; cd -"
export_alias _t "cd $TOP_HEAD && make test; cd -"
